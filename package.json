{
	"name": "turboflare",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.5.0",
	"scripts": {
		"build": "turbo run build",
		"check": "pnpm typecheck && pnpm test && pnpm test:integration && pnpm build && pnpm r2:lifecycle:dry-run",
		"deploy": "node scripts/deploy/cloudflare.mjs",
		"dev": "pnpm --filter @turboflare/cache-worker dev",
		"prune:smoke": "node scripts/ci/prune-smoke.mjs",
		"r2:lifecycle": "node scripts/r2/put-lifecycle.mjs",
		"r2:lifecycle:dry-run": "node scripts/r2/put-lifecycle.mjs --dry-run",
		"test": "turbo run test",
		"test:integration": "turbo run test:integration",
		"typecheck": "turbo run typecheck"
	},
	"devDependencies": {
		"turbo": "^2.6.1",
		"typescript": "^6.0.3"
	}
}
