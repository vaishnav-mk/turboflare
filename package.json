{
	"name": "turboflare",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.5.0",
	"scripts": {
		"build": "turbo run build",
		"check": "pnpm typecheck && pnpm test && pnpm test:integration && pnpm build",
		"dev": "pnpm --filter @turboflare/cache-worker dev",
